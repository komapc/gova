{
  "name": "gova",
  "version": "1.0.0",
  "description": "GPS-bazita alteco-monitorilo",
  "type": "module",
  "scripts": {
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
